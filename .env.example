# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=scenariotwin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=scenariotwin
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://scenariotwin:changeme@db:5432/scenariotwin

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── API Gateway ───────────────────────────────────────────────────────────────
API_SECRET_KEY=changeme-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ─── LLM Gateway (LiteLLM) ─────────────────────────────────────────────────────
LITELLM_MASTER_KEY=changeme
LITELLM_PORT=4000

# ─── LLM Provider Keys (injected into LiteLLM) ────────────────────────────────
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
# Optional: stronger model for narrator/guardrail steps
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── Service URLs (internal, Docker network) ───────────────────────────────────
SIMULATION_ENGINE_URL=http://simulation-engine:8001
AGENT_ORCHESTRATION_URL=http://agent-orchestration:8002
LLM_GATEWAY_URL=http://llm-gateway:4000

# ─── Feature flags ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
